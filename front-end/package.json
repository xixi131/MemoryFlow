{
  "name": "memoryflow",
  "private": true,
  "version": "1.0.8",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently -k \"npx cross-env BROWSER=none vite\" \"npx wait-on tcp:3000 && npx cross-env ELECTRON_START_URL=http://localhost:3000 electron .\"",
    "build": "vite build && electron-builder --config electron-builder.config.cjs",
    "release:win": "vite build && electron-builder --config electron-builder.config.cjs --win --x64 --publish always"
  },
  "dependencies": {
    "@coooookies/windows-smtc-monitor": "^1.0.12",
    "@milkdown/core": "^7.19.0",
    "@milkdown/plugin-history": "^7.19.0",
    "@milkdown/plugin-listener": "^7.19.0",
    "@milkdown/plugin-math": "^7.5.9",
    "@milkdown/plugin-prism": "^7.19.0",
    "@milkdown/plugin-table": "^5.3.1",
    "@milkdown/preset-commonmark": "^7.19.0",
    "@milkdown/react": "^7.19.0",
    "@milkdown/theme-nord": "^7.19.0",
    "axios": "^1.13.2",
    "electron-updater": "^6.6.2",
    "framer-motion": "^12.29.2",
    "katex": "^0.16.37",
    "lucide-react": "^0.563.0",
    "node-vibrant": "^4.0.4",
    "prismjs": "^1.30.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.23.0",
    "recharts": "^3.9.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "40.1.0",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3",
    "vite": "^6.1.0",
    "wait-on": "^6.0.1"
  },
  "description": "基于艾宾浩斯遗忘曲线的学习计划管理系统",
  "author": "MemoryFlow Team"
}
